{
    "cmd" : "md",
    "param" : {"enable":1, "Tbase": 2, "Tlum": 3, "obj_sensitivity": 90}
}

//Tbase: motion detect base threshold : smaller value, higher sensitive
//Tlum: motion detect threshold : smaller value, higher sensitive to light change
//dynamic_thr: enable dnamic threshold
//trigger_blocks: md triggered when at least n motion block triggered
